{
  "name": "prq",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev:api": "pnpm --filter @prq/api dev",
    "dev:web": "pnpm --filter @prq/web dev",
    "build": "pnpm --filter @prq/web build",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "eslint": "^10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
