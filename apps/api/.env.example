# Client ID of the GitHub OAuth App you registered for prq.
# Register at https://github.com/settings/applications/new with:
#   - Authorization callback URL: http://localhost:5173/
#   - Enable Device Flow: checked
# Tokens are long-lived; revoke from https://github.com/settings/applications.
# Copy this file to .env and paste the Client ID below.
PRQ_GITHUB_CLIENT_ID=

# Postgres connection string for Drizzle scripts and future hosted state.
# Local/test code paths have safe defaults:
#   development: postgres://prq:prq@localhost:5432/prq_dev
#   test:        postgres://prq:prq@localhost:5432/prq_test
# Production requires DATABASE_URL.
DATABASE_URL=

# Optional DB tuning. PRQ_DATABASE_SSL accepts disable, allow, prefer, require,
# verify-full, true, false, 1, or 0. Production defaults to require; local/test
# default to disable.
PRQ_DATABASE_SSL=
PRQ_DATABASE_MAX_CONNECTIONS=
