# GitHub App config.
# Register a GitHub App with:
#   - Callback URL: http://localhost:3001/api/auth/github/callback
#   - Setup URL: http://localhost:3001/api/auth/github/setup
#   - Redirect on update: enabled
#   - Request user authorization during installation: disabled
PRQ_GITHUB_CLIENT_ID=
PRQ_GITHUB_CLIENT_SECRET=
# Generate a GitHub App private key and either paste the PEM with literal
# newlines or encode its newlines as \n.
PRQ_GITHUB_PRIVATE_KEY=
PRQ_GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback
PRQ_WEB_URL=http://localhost:5173

# Set the same secret in the GitHub App webhook settings. Use JSON content type
# and http://localhost:3001/api/webhooks/github through a webhook tunnel.
PRQ_GITHUB_WEBHOOK_SECRET=

# Optional: enables /api/auth/github/install redirects.
PRQ_GITHUB_APP_SLUG=

# Postgres connection string for Drizzle scripts and hosted state.
# Local/test code paths have safe defaults:
#   development: postgres://prq:prq@localhost:5432/prq_dev
#   test:        postgres://prq:prq@localhost:5432/prq_test
# Production requires DATABASE_URL.
DATABASE_URL=

# Optional DB tuning. PRQ_DATABASE_SSL accepts disable, allow, prefer, require,
# verify-full, true, false, 1, or 0. Production defaults to require; local/test
# default to disable.
PRQ_DATABASE_SSL=
PRQ_DATABASE_MAX_CONNECTIONS=
